<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:internal="http://schemas.android.com/apk/prv/res/android" xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/swn_collapsed_hitspace"
    android:background="@drawable/notification_background"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    internal:opticalInsetTop="64dp"
    internal:opticalInsetRight="64dp">
    <include layout="@layout/stopwatch_notification_icon"/>
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="fill_vertical"
        android:orientation="vertical"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/notification_icon_size"
        android:paddingEnd="8dp"
        android:layout_marginStart="@dimen/notification_icon_size">
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/line1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp">
            <Chronometer
                android:textAppearance="@style/TextAppearance.StatusBar.EventContent.Title"
                android:id="@+id/swn_collapsed_chronometer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:layout_weight="1"/>
        </LinearLayout>
        <TextView
            android:textAppearance="@style/TextAppearance.StatusBar.EventContent"
            android:ellipsize="marquee"
            android:id="@+id/swn_collapsed_laps"
            android:visibility="gone"
            android:fadingEdge="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
</FrameLayout>
