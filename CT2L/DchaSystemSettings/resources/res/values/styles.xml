<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="@style/AppBaseTheme">
    </style>
    <style name="TallTitleBarTheme" parent="@android:style/Theme.NoTitleBar">
        <item name="android:windowContentOverlay">@null</item>
    </style>
    <style name="Theme.CreateShortCut" parent="@android:style/Theme.Holo.DialogWhenLarge">
    </style>
    <style name="wifi_item" parent="">
        <item name="android:gravity">0x800003</item>
        <item name="android:orientation">1</item>
        <item name="android:layout_width">-1</item>
        <item name="android:layout_height">-2</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_marginEnd">16dp</item>
    </style>
    <style name="wifi_item_advanced_togglebox" parent="">
        <item name="android:gravity">0x800003</item>
        <item name="android:orientation">1</item>
        <item name="android:layout_width">-2</item>
        <item name="android:layout_height">-2</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_marginEnd">16dp</item>
    </style>
    <style name="wifi_item_label" parent="">
        <item name="android:textSize">14sp</item>
        <item name="android:layout_width">-2</item>
        <item name="android:layout_height">-2</item>
    </style>
    <style name="wifi_item_content" parent="">
        <item name="android:textSize">18sp</item>
        <item name="android:layout_width">-1</item>
        <item name="android:layout_height">-2</item>
    </style>
    <style name="wifi_section" parent="">
        <item name="android:orientation">1</item>
        <item name="android:layout_width">-1</item>
        <item name="android:layout_height">-2</item>
    </style>
    <style name="main_layout_area" parent="">
        <item name="android:orientation">1</item>
        <item name="android:layout_width">1200dp</item>
        <item name="android:layout_height">600dp</item>
        <item name="android:layout_centerInParent">true</item>
    </style>
    <style name="setting_contents_btn" parent="">
        <item name="android:layout_width">120dp</item>
        <item name="android:layout_height">120dp</item>
        <item name="android:layout_marginTop">20dp</item>
        <item name="android:layout_marginRight">20dp</item>
    </style>
    <style name="Theme.Transparent" parent="@android:style/Theme.Translucent">
        <item name="android:windowBackground">@drawable/bg_black</item>
        <item name="android:windowNoTitle">true</item>
    </style>
    <style name="fontFamily" parent="@android:style/Widget.Holo.Light.TextView">
        <item name="android:fontFamily">gjsgm</item>
    </style>
    <style name="Theme.WifiDialog" parent="@android:style/Widget.DeviceDefault.Light.FragmentBreadCrumbs">
        <item name="android:windowSoftInputMode">0x10</item>
    </style>
</resources>
