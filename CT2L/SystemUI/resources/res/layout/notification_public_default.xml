<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:internal="http://schemas.android.com/apk/prv/res/android" xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/status_bar_latest_event_content"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    internal:opticalInsetTop="64dp"
    internal:opticalInsetRight="64dp">
    <ImageView
        android:id="@+id/icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="12dp"
        android:scaleType="centerInside"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"/>
    <DateTimeView
        android:textAppearance="@android:style/TextAppearance.Material.Notification.Time"
        android:gravity="center"
        android:id="@+id/time"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:layout_alignBaseline="@+id/title"
        android:paddingStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_alignParentEnd="true"/>
    <TextView
        android:textAppearance="@android:style/TextAppearance.Material.Notification.Title"
        android:ellipsize="marquee"
        android:id="@+id/title"
        android:fadingEdge="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:layout_toStartOf="@+id/time"
        android:layout_toEndOf="@+id/icon"/>
    <ImageView
        android:id="@+id/profile_badge_line3"
        android:visibility="gone"
        android:layout_width="@android:dimen/autofill_elevation"
        android:layout_height="@android:dimen/autofill_elevation"
        android:scaleType="fitCenter"
        android:layout_below="@+id/title"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="8dp"
        android:layout_alignParentEnd="true"/>
    <TextView
        android:textAppearance="@android:style/TextAppearance.Material.Notification"
        android:ellipsize="marquee"
        android:id="@+id/text"
        android:fadingEdge="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:layout_below="@+id/title"
        android:layout_toStartOf="@+id/profile_badge_line3"
        android:layout_alignStart="@+id/title"/>
</RelativeLayout>
