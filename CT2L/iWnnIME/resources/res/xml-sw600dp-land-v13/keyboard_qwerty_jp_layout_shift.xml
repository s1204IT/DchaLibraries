<?xml version="1.0" encoding="utf-8"?>
<Keyboard xmlns:iwnn="http://schemas.android.com/apk/res/jp.co.omronsoft.iwnnime.ml" xmlns:android="http://schemas.android.com/apk/res/android"
    iwnn:horizontalGap="@fraction/keyboard_qwerty_common_horizontal_gap"
    iwnn:keyWidth="@fraction/keyboard_qwerty_common_keywidth">
    <switch>
        <case iwnn:keyboardCondition="keyNumberOn">
            <Row>
                <include iwnn:keyboardLayout="@xml/key_qwerty_jp_row_number"/>
                <Key
                    iwnn:codes="-100"
                    iwnn:isRepeatable="true"
                    iwnn:keyEdgeFlags="right"
                    iwnn:keyIcon="@drawable/key_del"
                    iwnn:isSecondKey="true"
                    iwnn:keyHeightRow="2"
                    iwnn:description="@string/ti_description_key_backspace"/>
            </Row>
            <Row>
                <include iwnn:keyboardLayout="@xml/key_qwerty_jp_row1_q_to_p_shift"/>
                <Key iwnn:isEmpty="true"/>
            </Row>
        </case>
        <case iwnn:keyboardCondition="keyNumberOff">
            <Row>
                <include iwnn:keyboardLayout="@xml/key_qwerty_jp_row1_q_to_p_shift"/>
                <Key
                    iwnn:codes="-100"
                    iwnn:isRepeatable="true"
                    iwnn:keyEdgeFlags="right"
                    iwnn:keyIcon="@drawable/key_del"
                    iwnn:isSecondKey="true"
                    iwnn:description="@string/ti_description_key_backspace"/>
            </Row>
        </case>
    </switch>
    <Row iwnn:rowGravity="right">
        <include iwnn:keyboardLayout="@xml/key_qwerty_jp_row2_a_to_l_shift"/>
        <Key
            iwnn:codes="-101"
            iwnn:keyEdgeFlags="right"
            iwnn:keyIcon="@drawable/key_enter"
            iwnn:keyWidth="@fraction/keyboard_qwerty_enter_keywidth"
            iwnn:isSecondKey="true"/>
    </Row>
    <Row iwnn:rowGravity="left">
        <include iwnn:keyboardLayout="@xml/key_qwerty_jp_row3_shiftlockkey"/>
        <include iwnn:keyboardLayout="@xml/key_qwerty_jp_row3_z_to_m_shift"/>
        <include iwnn:keyboardLayout="@xml/key_qwerty_jp_tyouon_shift"/>
        <include iwnn:keyboardLayout="@xml/key_qwerty_jp_close"/>
    </Row>
    <Row iwnn:rowEdgeFlags="bottom">
        <include iwnn:keyboardLayout="@xml/row_qwerty_jp_shift_4"/>
    </Row>
</Keyboard>
