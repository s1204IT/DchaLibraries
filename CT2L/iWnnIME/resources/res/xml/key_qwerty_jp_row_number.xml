                </case>
            </case>
        </case>
        <case iwnn:keyboardCondition="keyNumberOn|modeHalfKatakana">
            <case iwnn:keyboardCondition="keyNumberOn|modeHalfAlpha">
                <case iwnn:keyboardCondition="modeHalfNum">
                    <Row-Key>
                        <Key
