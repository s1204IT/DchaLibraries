<?xml version="1.0" encoding="utf-8"?>
<Keyboard xmlns:iwnn="http://schemas.android.com/apk/res/jp.co.omronsoft.iwnnime.ml" xmlns:android="http://schemas.android.com/apk/res/android">
    <switch>
        <case iwnn:keyboardCondition="modeHiragana">
            <Row-Key>
                <Key
                    iwnn:codes="-114"
                    iwnn:keyEdgeFlags="left"
                    iwnn:popupKeyboard="@xml/keyboard_switch_key_jp"
                    iwnn:keyWidth="@fraction/keyboard_50key_function_keywidth"
                    iwnn:isSecondKey="true"/>
            </Row-Key>
        </case>
        <case iwnn:keyboardCondition="modeFullAlpha">
            <Row-Key>
                <Key
                    iwnn:codes="-114"
                    iwnn:keyEdgeFlags="left"
                    iwnn:popupKeyboard="@xml/keyboard_switch_key_jp"
                    iwnn:keyWidth="@fraction/keyboard_50key_function_keywidth"
                    iwnn:isSecondKey="true"/>
            </Row-Key>
        </case>
        <case iwnn:keyboardCondition="modeFullNum">
            <Row-Key>
                <Key
                    iwnn:codes="-114"
                    iwnn:keyEdgeFlags="left"
                    iwnn:popupKeyboard="@xml/keyboard_switch_key_jp"
                    iwnn:keyWidth="@fraction/keyboard_50key_function_keywidth"
                    iwnn:isSecondKey="true"/>
            </Row-Key>
        </case>
        <case iwnn:keyboardCondition="modeFullKatakana">
            <Row-Key>
                <Key
                    iwnn:codes="-114"
                    iwnn:keyEdgeFlags="left"
                    iwnn:popupKeyboard="@xml/keyboard_switch_key_jp"
                    iwnn:keyWidth="@fraction/keyboard_50key_function_keywidth"
                    iwnn:isSecondKey="true"/>
            </Row-Key>
        </case>
        <case iwnn:keyboardCondition="modeHalfAlpha">
            <Row-Key>
                <Key
                    iwnn:codes="-114"
                    iwnn:keyEdgeFlags="left"
                    iwnn:popupKeyboard="@xml/keyboard_switch_key_jp"
                    iwnn:keyWidth="@fraction/keyboard_50key_function_keywidth"
                    iwnn:isSecondKey="true"/>
            </Row-Key>
        </case>
        <case iwnn:keyboardCondition="modeHalfNum">
            <Row-Key>
                <Key
                    iwnn:codes="-114"
                    iwnn:keyEdgeFlags="left"
                    iwnn:popupKeyboard="@xml/keyboard_switch_key_jp"
                    iwnn:keyWidth="@fraction/keyboard_50key_function_keywidth"
                    iwnn:isSecondKey="true"/>
            </Row-Key>
        </case>
        <case iwnn:keyboardCondition="modeHalfKatakana">
            <Row-Key>
                <Key
                    iwnn:codes="-114"
                    iwnn:keyEdgeFlags="left"
                    iwnn:popupKeyboard="@xml/keyboard_switch_key_jp"
                    iwnn:keyWidth="@fraction/keyboard_50key_function_keywidth"
                    iwnn:isSecondKey="true"/>
            </Row-Key>
        </case>
    </switch>
</Keyboard>
