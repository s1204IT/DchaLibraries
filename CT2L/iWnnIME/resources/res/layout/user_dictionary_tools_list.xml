<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:paddingTop="5sp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:orientation="horizontal"
        android:id="@+id/user_dictionary_screen_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textColor="?android:attr/textColorPrimary"
            android:id="@+id/user_dictionary_tools_list_title_language"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"/>
        <TextView
            android:textColor="?android:attr/textColorPrimary"
            android:id="@+id/user_dictionary_tools_list_title_words_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/user_dictionary_screen_base"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <Button
                android:id="@+id/user_dictionary_left_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ti_user_dictionary_prev_button_txt"/>
            <TextView
                android:gravity="center"
                android:id="@+id/user_dictionary_position_indicator"
                android:layout_width="100sp"
                android:layout_height="wrap_content"/>
            <Button
                android:id="@+id/user_dictionary_right_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ti_user_dictionary_next_button_txt"/>
        </LinearLayout>
        <LinearLayout
            android:layout_gravity="left"
            android:orientation="horizontal"
            android:padding="1dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="16dp"
                android:textColor="?android:attr/textColorTertiary"
                android:id="@+id/user_dictionary_title_read"
                android:background="#ffffff"
                android:focusable="false"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="0dp"
                android:layout_marginTop="1dp"
                android:layout_marginRight="1dp"
                android:layout_marginBottom="1dp"
                android:text="@string/ti_user_dictionary_title_read_txt"
                android:layout_weight="1"/>
            <TextView
                android:textSize="16dp"
                android:textColor="?android:attr/textColorTertiary"
                android:background="#ffffff"
                android:focusable="false"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="1dp"
                android:layout_marginTop="1dp"
                android:layout_marginRight="0dp"
                android:layout_marginBottom="1dp"
                android:text="@string/ti_user_dictionary_title_candidate_txt"
                android:layout_weight="1"/>
        </LinearLayout>
        <ScrollView
            android:id="@+id/user_dictionary_tools_scroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TableLayout
                android:id="@+id/user_dictionary_tools_table"
                android:padding="1dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </ScrollView>
    </LinearLayout>
</LinearLayout>
