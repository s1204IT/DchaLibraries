<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ScrollView
        android:id="@+id/candview_scroll"
        android:background="@color/candidate_back"
        android:scrollbars="vertical"
        android:fadingEdgeLength="0dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fadeScrollbars="false"
        android:importantForAccessibility="no">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/candview_base"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <AbsoluteLayout
                    android:id="@+id/candidates_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <AbsoluteLayout
                    android:id="@+id/candidates_hint_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </FrameLayout>
            <TextView
                android:textSize="@dimen/candidate_are_nothing_label_text_size"
                android:textColor="@color/candidate_text"
                android:id="@+id/candidates_are_nothing"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/ti_candidates_are_nothing_txt"
                android:importantForAccessibility="no"/>
            <TextView
                android:textSize="@dimen/candidate_are_nothing_label_text_size"
                android:textColor="@color/candidate_text"
                android:id="@+id/candidates_are_no_history"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/ti_candidates_are_no_history_txt"
                android:importantForAccessibility="no"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
