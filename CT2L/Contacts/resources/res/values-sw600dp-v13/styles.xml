<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="DirectoryHeader" parent="@style/PeopleTheme">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:paddingTop">0dp</item>
    </style>
    <style name="ContactListFilterTheme" parent="@android:style/Theme.Holo.Light.Dialog">
        <item name="android:listViewStyle">@style/ListViewStyle</item>
        <item name="android:windowCloseOnTouchOutside">true</item>
    </style>
    <style name="CustomContactListFilterView" parent="@style/ContactListFilterTheme">
        <item name="android:layout_width">-1</item>
        <item name="android:layout_height">400dp</item>
    </style>
    <style name="DetailActivityTheme" parent="@android:style/Theme.Dialog">
        <item name="android:windowContentOverlay">@null</item>
    </style>
    <style name="ContactPickerLayout" parent="@style/ContactPickerTheme">
        <item name="android:layout_width">-1</item>
        <item name="android:layout_height">-1</item>
    </style>
    <style name="ConfirmAddDetailViewStyle" parent="">
        <item name="android:layout_width">-1</item>
        <item name="android:layout_height">-2</item>
    </style>
    <style name="ConfirmAddDetailHeaderViewStyle" parent="">
        <item name="android:layout_width">-1</item>
        <item name="android:layout_height">200dp</item>
    </style>
</resources>
