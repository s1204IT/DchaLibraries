<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:scrollbars="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ScrollView
        android:scrollbarStyle="outsideOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="?android:attr/listPreferredItemPaddingStart"
            android:paddingEnd="?android:attr/listPreferredItemPaddingEnd">
            <View
                android:background="#ff404040"
                android:paddingTop="53dp"
                android:layout_width="match_parent"
                android:layout_height="1dp"/>
            <EditText
                android:gravity="top"
                android:id="@+id/owner_info_nickname"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/user_nickname"
                android:inputType="textCapWords"/>
            <CheckBox
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:textColor="?android:attr/textColorSecondary"
                android:gravity="center_vertical"
                android:id="@+id/show_owner_info_on_lockscreen_checkbox"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="8dp"
                android:text="@string/show_owner_info_on_lockscreen_label"/>
            <View
                android:background="#ff404040"
                android:layout_width="match_parent"
                android:layout_height="1dp"/>
            <EditText
                android:gravity="top"
                android:id="@+id/owner_info_edit_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:hint="@string/owner_info_settings_edit_text_hint"
                android:maxLines="8"
                android:lines="8"
                android:inputType="textMultiLine"
                android:layout_marginStart="62dp"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
