<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="QSBBar" parent="">
        <item name="android:layout_gravity">0x800003</item>
        <item name="android:orientation">1</item>
        <item name="android:layout_width">@dimen/qsb_bar_height</item>
        <item name="android:layout_height">-1</item>
    </style>
    <style name="SearchDropTargetBar" parent="">
        <item name="android:layout_gravity">0x1</item>
        <item name="android:orientation">1</item>
        <item name="android:layout_width">-1</item>
        <item name="android:layout_height">-2</item>
    </style>
    <style name="SearchButton" parent="">
        <item name="android:layout_gravity">0x1</item>
        <item name="android:paddingTop">@dimen/toolbar_button_vertical_padding</item>
        <item name="android:paddingBottom">@dimen/toolbar_button_vertical_padding</item>
        <item name="android:paddingStart">@dimen/toolbar_button_horizontal_padding</item>
        <item name="android:paddingEnd">@dimen/toolbar_button_horizontal_padding</item>
    </style>
    <style name="DropTargetButtonContainer" parent="">
        <item name="android:layout_width">-1</item>
        <item name="android:layout_height">0dp</item>
    </style>
    <style name="DropTargetButton" parent="">
        <item name="android:gravity">0x11</item>
        <item name="android:layout_gravity">0x11</item>
        <item name="android:paddingTop">@dimen/toolbar_button_vertical_padding</item>
        <item name="android:paddingBottom">@dimen/toolbar_button_vertical_padding</item>
        <item name="android:layout_width">-2</item>
        <item name="android:layout_height">-2</item>
        <item name="android:shadowColor">#dd000000</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">4</item>
        <item name="android:paddingStart">@dimen/toolbar_button_horizontal_padding</item>
        <item name="android:paddingEnd">@dimen/toolbar_button_horizontal_padding</item>
    </style>
    <style name="TabIndicator.AppsCustomize" parent="@style/TabIndicator">
        <item name="android:maxWidth">200dp</item>
    </style>
</resources>
