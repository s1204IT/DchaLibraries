<?xml version="1.0" encoding="utf-8"?>
<com.android.camera.widget.AspectRatioSelector xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/aspect_ratio_selector">
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/aspect_ratio_4x3_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="28dp"
            android:src="@drawable/aspect_ratio_4x3"
            android:contentDescription="@string/full_sensor_4x3_aspect_ratio"/>
        <ImageView
            android:id="@+id/aspect_ratio_16x9_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="28dp"
            android:src="@drawable/aspect_ratio_16x9"
            android:contentDescription="@string/cropped_sensor_16x9_aspect_ratio"/>
    </LinearLayout>
</com.android.camera.widget.AspectRatioSelector>
