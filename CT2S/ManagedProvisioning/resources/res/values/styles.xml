<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="SetupWorkSpaceTheme" parent="@android:style/Theme.Material.Light">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:colorPrimary">@color/teal</item>
        <item name="android:colorPrimaryDark">@color/light_teal</item>
        <item name="android:colorAccent">@color/dark_turquoise</item>
    </style>
    <style name="LightButtonOverlayTheme" parent="">
        <item name="android:textColorPrimary">@color/accent</item>
        <item name="android:colorButtonNormal">@color/white</item>
        <item name="android:colorControlHighlight">@color/accent_transparent</item>
    </style>
    <style name="ColoredButtonOverlayTheme" parent="">
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:colorButtonNormal">@color/colored_button</item>
    </style>
    <style name="ControlOverlayTheme" parent="">
        <item name="android:colorControlNormal">@color/accent_transparent</item>
    </style>
    <style name="Container" parent="">
        <item name="android:orientation">1</item>
        <item name="android:background">@color/teal</item>
        <item name="android:layout_width">-1</item>
        <item name="android:layout_height">-1</item>
    </style>
    <style name="HeaderAndTitleContainer" parent="">
        <item name="android:orientation">1</item>
        <item name="android:background">@color/teal</item>
        <item name="android:layout_width">-1</item>
        <item name="android:layout_height">-2</item>
    </style>
    <style name="HeaderImage" parent="">
        <item name="android:layout_width">-1</item>
        <item name="android:layout_height">-2</item>
        <item name="android:src">@drawable/setup_illustration</item>
        <item name="android:scaleType">6</item>
        <item name="android:adjustViewBounds">true</item>
    </style>
    <style name="Title" parent="">
        <item name="android:textSize">@dimen/title_text_size</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:gravity">0x10</item>
        <item name="android:background">@color/teal</item>
        <item name="android:paddingLeft">@dimen/title_padding</item>
        <item name="android:layout_width">-1</item>
        <item name="android:layout_height">@dimen/title_height</item>
    </style>
    <style name="MainText" parent="">
        <item name="android:textSize">@dimen/main_text_size</item>
        <item name="android:textColor">@color/text_black</item>
        <item name="android:paddingTop">@dimen/main_text_padding_between_text</item>
        <item name="android:layout_width">-1</item>
        <item name="android:layout_height">-2</item>
    </style>
    <style name="ColoredButton" parent="@android:style/Widget.Material.Light.Button">
        <item name="android:theme">@style/ColoredButtonOverlayTheme</item>
        <item name="android:textSize">@dimen/main_text_size</item>
        <item name="android:gravity">0x11</item>
        <item name="android:layout_width">-2</item>
        <item name="android:layout_height">-2</item>
        <item name="android:minWidth">@dimen/button_width</item>
    </style>
    <style name="LightButton" parent="@android:style/Widget.Material.Light.Button">
        <item name="android:theme">@style/LightButtonOverlayTheme</item>
        <item name="android:textSize">@dimen/main_text_size</item>
        <item name="android:gravity">0x11</item>
        <item name="android:layout_width">-2</item>
        <item name="android:layout_height">-2</item>
        <item name="android:minWidth">@dimen/button_width</item>
    </style>
    <style name="TransparentButton" parent="@android:style/Widget.Material.Light.Button">
        <item name="android:textColorPrimary">@color/colored_button</item>
        <item name="android:textSize">@dimen/main_text_size</item>
        <item name="android:gravity">0x11</item>
        <item name="android:background">@color/transparent</item>
        <item name="android:layout_width">-2</item>
        <item name="android:layout_height">-2</item>
        <item name="android:minWidth">@dimen/button_width</item>
    </style>
    <style name="MainTextContainer" parent="">
        <item name="android:textSize">@dimen/main_text_size</item>
        <item name="android:orientation">1</item>
        <item name="android:background">@color/white</item>
        <item name="android:paddingLeft">@dimen/main_text_padding_left_right</item>
        <item name="android:paddingTop">@dimen/main_text_padding_top</item>
        <item name="android:paddingRight">@dimen/main_text_padding_left_right</item>
        <item name="android:paddingBottom">@dimen/main_text_padding_bottom</item>
        <item name="android:layout_width">-1</item>
        <item name="android:layout_height">-1</item>
        <item name="android:layout_marginLeft">@dimen/main_text_margins_left_right</item>
        <item name="android:layout_marginRight">@dimen/main_text_margins_left_right</item>
    </style>
    <style name="DialogFragmentTextContainer" parent="">
        <item name="android:textSize">@dimen/main_text_size</item>
        <item name="android:orientation">1</item>
        <item name="android:background">@color/white</item>
        <item name="android:paddingLeft">@dimen/dialog_text_padding_left_right</item>
        <item name="android:paddingTop">@dimen/dialog_text_padding_top</item>
        <item name="android:paddingRight">@dimen/dialog_text_padding_left_right</item>
        <item name="android:paddingBottom">@dimen/dialog_text_padding_bottom</item>
        <item name="android:layout_width">-1</item>
        <item name="android:layout_height">-1</item>
    </style>
    <style name="ScrollView" parent="@android:style/Widget.Material.Light.ScrollView">
        <item name="android:theme">@style/ControlOverlayTheme</item>
        <item name="android:layout_width">-1</item>
        <item name="android:fadeScrollbars">false</item>
    </style>
    <style name="ProgressBar" parent="@android:style/Widget.Material.ProgressBar">
        <item name="android:layout_width">-1</item>
        <item name="android:layout_height">-2</item>
        <item name="android:layout_marginTop">@dimen/main_text_padding_between_text</item>
        <item name="android:indeterminate">true</item>
    </style>
    <style name="ManagedProvisioningDialogTheme" parent="@android:style/Theme.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>
