<?xml version="1.0" encoding="utf-8"?>
<com.android.launcher2.Cling xmlns:launcher="http://schemas.android.com/apk/res/com.android.launcher" xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    launcher:drawIdentifier="workspace_landscape">
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="40dp"
        android:layout_marginStart="40dp">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/workspace_cling_title"
                style="@style/ClingTitleText"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/workspace_cling_move_item"
                style="@style/ClingText"/>
        </LinearLayout>
    </FrameLayout>
    <TextView
        android:gravity="end"
        android:layout_gravity="end|center_vertical"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:text="@string/workspace_cling_open_all_apps"
        android:layout_marginEnd="130dp"
        style="@style/ClingText"/>
    <Button
        android:layout_gravity="end|bottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="15dp"
        android:onClick="dismissWorkspaceCling"
        android:layout_marginEnd="10dp"
        style="@style/ClingButton"/>
</com.android.launcher2.Cling>
