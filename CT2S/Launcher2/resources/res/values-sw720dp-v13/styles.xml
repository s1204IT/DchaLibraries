<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.WallpaperPicker" parent="@style/Theme">
        <item name="android:screenOrientation">-1</item>
    </style>
    <style name="Theme" parent="@android:style/Theme.Holo.Wallpaper.NoTitleBar">
        <item name="android:windowActionModeOverlay">true</item>
    </style>
    <style name="ClingButton" parent="">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">0x1</item>
        <item name="android:background">@drawable/cling_button_bg</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">15dp</item>
        <item name="android:layout_width">-2</item>
        <item name="android:layout_height">-2</item>
        <item name="android:text">@string/cling_dismiss</item>
        <item name="android:paddingStart">35dp</item>
        <item name="android:paddingEnd">35dp</item>
    </style>
    <style name="ClingTitleText" parent="">
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">#49c0ec</item>
        <item name="android:layout_width">-2</item>
        <item name="android:layout_height">-2</item>
        <item name="android:layout_marginBottom">5dp</item>
        <item name="android:shadowColor">#000000</item>
        <item name="android:shadowDy">2</item>
        <item name="android:shadowRadius">2</item>
    </style>
    <style name="ClingText" parent="">
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">#ffffff</item>
        <item name="android:shadowColor">#000000</item>
        <item name="android:shadowDy">2</item>
        <item name="android:shadowRadius">2</item>
        <item name="android:lineSpacingMultiplier">1.1</item>
    </style>
    <style name="WorkspaceIcon.Portrait" parent="@style/WorkspaceIcon">
        <item name="android:textSize">16sp</item>
        <item name="android:paddingTop">@dimen/app_icon_padding_top</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:drawablePadding">0dp</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">4dp</item>
    </style>
    <style name="WorkspaceIcon.Landscape" parent="@style/WorkspaceIcon">
        <item name="android:textSize">16sp</item>
        <item name="android:paddingTop">@dimen/app_icon_padding_top</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:drawablePadding">0dp</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">4dp</item>
    </style>
    <style name="WorkspaceIcon.Portrait.Folder" parent="@style/WorkspaceIcon.Portrait">
        <item name="android:textSize">16sp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:layout_marginTop">-2dp</item>
        <item name="android:shadowRadius">0</item>
        <item name="android:drawablePadding">0dp</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">4dp</item>
    </style>
    <style name="WorkspaceIcon.Landscape.Folder" parent="@style/WorkspaceIcon.Landscape">
        <item name="android:textSize">16sp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:layout_marginTop">-2dp</item>
        <item name="android:shadowRadius">0</item>
        <item name="android:drawablePadding">0dp</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">4dp</item>
    </style>
    <style name="WorkspaceIcon.Portrait.AppsCustomize" parent="@style/WorkspaceIcon.Portrait">
        <item name="android:textSize">16sp</item>
        <item name="android:background">@null</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:shadowRadius">0</item>
        <item name="android:drawablePadding">0dp</item>
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
    </style>
    <style name="WorkspaceIcon.Landscape.AppsCustomize" parent="@style/WorkspaceIcon.Landscape">
        <item name="android:textSize">16sp</item>
        <item name="android:background">@null</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:shadowRadius">0</item>
        <item name="android:drawablePadding">0dp</item>
    </style>
    <style name="QSBBar" parent="">
        <item name="android:layout_gravity">0x31</item>
        <item name="android:orientation">0</item>
        <item name="android:layout_width">-1</item>
        <item name="android:layout_height">@dimen/qsb_bar_height</item>
        <item name="android:paddingStart">@dimen/qsb_padding_left</item>
        <item name="android:paddingEnd">@dimen/qsb_padding_right</item>
    </style>
    <style name="SearchDropTargetBar" parent="">
        <item name="android:layout_gravity">0x51</item>
        <item name="android:orientation">0</item>
        <item name="android:layout_width">-1</item>
        <item name="android:layout_height">-1</item>
    </style>
    <style name="SearchButton" parent="">
        <item name="android:layout_gravity">0x10</item>
        <item name="android:paddingTop">@dimen/toolbar_button_vertical_padding</item>
        <item name="android:paddingBottom">@dimen/toolbar_button_vertical_padding</item>
    </style>
    <style name="DropTargetButtonContainer" parent="">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">-1</item>
    </style>
    <style name="DropTargetButton" parent="">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#ffffffff</item>
        <item name="android:gravity">0x10</item>
        <item name="android:layout_gravity">0x11</item>
        <item name="android:layout_width">-2</item>
        <item name="android:layout_height">-1</item>
        <item name="android:shadowColor">#393939</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:shadowRadius">2</item>
        <item name="android:drawablePadding">7.5dp</item>
        <item name="android:paddingStart">60dp</item>
        <item name="android:paddingEnd">60dp</item>
    </style>
    <style name="TabIndicator.AppsCustomize" parent="@style/TabIndicator">
        <item name="android:textSize">17sp</item>
        <item name="android:maxWidth">240dp</item>
        <item name="android:paddingStart">32dp</item>
        <item name="android:paddingEnd">32dp</item>
    </style>
</resources>
