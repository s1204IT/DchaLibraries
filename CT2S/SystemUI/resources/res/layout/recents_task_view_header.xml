<?xml version="1.0" encoding="utf-8"?>
<com.android.systemui.recents.views.TaskViewHeader xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="top|center_horizontal"
    android:id="@+id/task_view_bar"
    android:layout_width="match_parent"
    android:layout_height="@dimen/recents_task_bar_height">
    <com.android.systemui.recents.views.FixedSizeImageView
        android:layout_gravity="start|center_vertical"
        android:id="@+id/application_icon"
        android:background="@drawable/recents_button_bg"
        android:padding="8dp"
        android:layout_width="@dimen/recents_task_view_application_icon_size"
        android:layout_height="@dimen/recents_task_view_application_icon_size"
        android:layout_marginStart="8dp"/>
    <TextView
        android:textSize="16sp"
        android:textColor="#ffffffff"
        android:ellipsize="marquee"
        android:layout_gravity="start|center_vertical"
        android:id="@+id/activity_description"
        android:fadingEdge="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/recents_empty_message"
        android:maxLines="2"
        android:singleLine="true"
        android:fontFamily="sans-serif-medium"
        android:layout_marginStart="64dp"
        android:layout_marginEnd="64dp"/>
    <com.android.systemui.recents.views.FixedSizeImageView
        android:layout_gravity="end|center_vertical"
        android:id="@+id/dismiss_task"
        android:background="@drawable/recents_button_bg"
        android:padding="12dp"
        android:visibility="invisible"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/recents_dismiss_light"
        android:layout_marginEnd="4dp"/>
</com.android.systemui.recents.views.TaskViewHeader>
